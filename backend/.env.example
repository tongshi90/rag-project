# RAG 系统配置文件

# ============================================
# API 密钥
# ============================================
SILICONFLOW_API_KEY=sk-edvfxjljpvthsvcgkikydaqxnktvcwhedacvcoddmxjgiexq

# ============================================
# OCR 配置 (图片文字识别)
# ============================================
SILICONFLOW_OCR_URL=https://api.siliconflow.cn/v1/chat/completions
SILICONFLOW_OCR_MODEL=Qwen/Qwen2-VL-72B-Instruct
OCR_TIMEOUT=60
OCR_DEFAULT_PROMPT=请识别图片中的所有文字内容，包括表格和标题，保持原有格式。

# ============================================
# Chat LLM 配置 (对话生成)
# ============================================
SILICONFLOW_CHAT_URL=https://api.siliconflow.cn/v1/chat/completions
SILICONFLOW_CHAT_MODEL=Qwen/Qwen2.5-72B-Instruct
CHAT_TIMEOUT=60
CHAT_MAX_TOKENS=4096
CHAT_TEMPERATURE=0.5

# ============================================
# Embedding 配置 (向量化)
# ============================================
SILICONFLOW_EMBEDDING_URL=https://api.siliconflow.cn/v1/embeddings
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_TIMEOUT=90
EMBEDDING_BATCH_SIZE=10
EMBEDDING_MAX_RETRIES=3

# ============================================
# Text Splitter 配置 (轻量级模型，用于分片优化/问题拆分)
# ============================================
SILICONFLOW_TEXT_SPLITTER_MODEL=Qwen/Qwen2.5-7B-Instruct
TEXT_SPLITTER_TIMEOUT=60
TEXT_SPLITTER_TEMPERATURE=0.3

# ============================================
# Rerank 配置 (重排序)
# ============================================
SILICONFLOW_RERANK_URL=https://api.siliconflow.cn/v1/rerank
SILICONFLOW_RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B
RERANK_TIMEOUT=30

# ============================================
# Flask 服务配置
# ============================================
PORT=5000
FLASK_DEBUG=True

# 服务器外部访问地址（可选，用于 Docker 部署或反向代理场景）
# 留空则自动从请求头获取
# 示例：http://localhost:5000 或 https://your-domain.com
SERVER_BASE_URL=

# ============================================
# 文件上传配置
# ============================================
UPLOAD_FOLDER=data/upload
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=pdf

# ============================================
# 数据库配置
# ============================================
DATABASE_PATH=data/rag.db

# ============================================
# 向量数据库配置
# ============================================
VECTOR_DB_PATH=data/vector_db
VECTOR_DB_COLLECTION_NAME=rag_chunks

# ============================================
# 知识图谱配置
# ============================================
GRAPH_DB_PATH=data/graph
GRAPH_STORAGE_TYPE=memory

# ============================================
# 关键字索引配置
# ============================================
KEYWORD_INDEX_PATH=data/keyword_index

# ============================================
# 混合检索权重配置
# ============================================
VECTOR_WEIGHT=0.5
KEYWORD_WEIGHT=0.3
GRAPH_WEIGHT=0.2

# ============================================
# 实体抽取配置
# ============================================
ENTITY_EXTRACTION_MODEL=Qwen/Qwen2.5-7B-Instruct
ENTITY_EXTRACTION_BATCH_SIZE=5
ENTITY_CONFIDENCE_THRESHOLD=0.7

# ============================================
# 图谱检索配置
# ============================================
GRAPH_HOP_DEPTH=2
GRAPH_MAX_NEIGHBORS=20

# ============================================
# 关键字提取配置
# ============================================
KEYWORD_EXTRACTION_TOP_K=10
